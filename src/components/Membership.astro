---
import config from '../../site.json';
const tiers = config.membership;
---
<section id="membership" class="py-24 px-6 lg:px-12 bg-base-200">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <h2 class="text-5xl md:text-6xl font-heading font-bold uppercase tracking-wide">Membership Plans</h2>
      <p class="text-base-content/50 mt-4 uppercase tracking-wider text-sm">No contracts. No excuses. Just results.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto items-center stagger-children">
      {tiers.map((tier) => (
        <div class={`card bg-base-100 shadow-lg transition-all duration-300 ${tier.highlighted ? 'scale-105 border-2 border-accent shadow-xl' : 'border border-base-300'}`}>
          {tier.highlighted && (
            <div class="indicator w-full">
              <span class="indicator-item badge badge-accent font-bold uppercase tracking-wider">Most Popular</span>
            </div>
          )}
          <div class="card-body p-8 text-center">
            <h3 class="text-2xl font-heading uppercase tracking-wide">{tier.name}</h3>
            <div class="my-4">
              <span class="text-6xl font-heading font-bold text-accent">${tier.price}</span>
              <span class="text-base-content/40 text-sm">/{tier.period}</span>
            </div>

            <ul class="text-left space-y-3 mb-8">
              {tier.features.map((feature: string) => (
                <li class="flex items-center gap-3 text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-base-content/70">{feature}</span>
                </li>
              ))}
            </ul>

            <button class={`btn w-full uppercase tracking-wider font-bold ${tier.highlighted ? 'btn-accent' : 'btn-outline'}`}>
              {tier.highlighted ? 'Start Free Trial' : 'Get Started'}
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
