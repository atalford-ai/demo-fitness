---
import config from '../../site.json';
const tiers = config.membership;
---
<section id="membership" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Pricing</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Membership Plans</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">No contracts, no hidden fees. Just results. Start your free trial today.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto stagger-children">
      {tiers.map((tier) => (
        <div class={`card bg-base-200 shadow-md hover:shadow-xl transition-all duration-300 ${tier.highlighted ? 'border-2 border-accent scale-105 relative' : 'border border-base-300/50'}`}>
          {tier.highlighted && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="badge badge-accent font-semibold px-4 py-3">Most Popular</span>
            </div>
          )}

          <div class="card-body p-8 text-center">
            <h3 class="font-heading font-semibold text-xl mb-2">{tier.name}</h3>
            <div class="mb-6">
              <span class="text-5xl font-heading font-bold text-accent">${tier.price}</span>
              <span class="text-base-content/50 text-sm">/{tier.period}</span>
            </div>

            <ul class="space-y-3 text-left mb-8">
              {tier.features.map((feature: string) => (
                <li class="flex items-center gap-3 text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-base-content/70">{feature}</span>
                </li>
              ))}
            </ul>

            <button class={`btn w-full ${tier.highlighted ? 'btn-accent' : 'btn-outline'}`}>
              {tier.highlighted ? 'Start Free Trial' : 'Get Started'}
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
