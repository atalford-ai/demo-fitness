---
import config from '../../site.json';
const trainers = config.trainers;
---
<section id="trainers" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <h2 class="text-5xl md:text-6xl font-heading font-bold uppercase tracking-wide">Meet the Team</h2>
      <p class="text-base-content/50 mt-4 uppercase tracking-wider text-sm">Certified. Dedicated. Relentless.</p>
    </div>

    <div class="flex flex-col gap-6 max-w-4xl mx-auto stagger-children">
      {trainers.map((trainer) => (
        <div class="card card-side bg-base-200 shadow-xl">
          <figure class="w-48 min-h-48 shrink-0">
            <img src={trainer.image} alt={trainer.name} class="w-full h-full object-cover" loading="lazy" />
          </figure>
          <div class="card-body">
            <h3 class="card-title text-2xl font-heading uppercase tracking-wide">{trainer.name}</h3>
            <p class="text-accent text-sm font-bold uppercase tracking-wider">{trainer.specialty}</p>
            <p class="text-base-content/60 text-sm leading-relaxed mt-1">{trainer.bio}</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {trainer.certifications.map((cert: string) => (
                <span class="badge badge-outline badge-sm">{cert}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
