---
import config from '../../site.json';
---
<section class="hero min-h-screen" style="background-image: url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1600&h=900&fit=crop');">
  <div class="hero-overlay bg-black/75"></div>
  <div class="hero-content text-center text-neutral-content flex-col">
    <div class="max-w-4xl fade-in-up">
      <p class="text-accent uppercase tracking-[0.3em] text-sm font-bold mb-4">No Excuses. No Limits.</p>
      <h1 class="text-7xl md:text-8xl lg:text-9xl font-heading font-bold leading-none uppercase tracking-wide mb-6">
        Push Past<br />Every Limit
      </h1>
      <p class="text-lg text-white/60 max-w-lg mx-auto mb-8">
        {config.description}
      </p>

      <!-- Stats row -->
      <div class="stats stats-horizontal bg-transparent shadow-none mb-10">
        <div class="stat">
          <div class="stat-value text-accent text-4xl font-heading">2,500+</div>
          <div class="stat-desc text-white/50 uppercase tracking-wider text-xs">Active Members</div>
        </div>
        <div class="stat">
          <div class="stat-value text-accent text-4xl font-heading">40+</div>
          <div class="stat-desc text-white/50 uppercase tracking-wider text-xs">Classes / Week</div>
        </div>
        <div class="stat">
          <div class="stat-value text-accent text-4xl font-heading">8</div>
          <div class="stat-desc text-white/50 uppercase tracking-wider text-xs">Years Strong</div>
        </div>
      </div>

      <a href="#membership" class="btn btn-accent btn-lg uppercase tracking-widest font-bold px-12">
        Start Free Trial
      </a>
      <p class="mt-4 text-xs text-white/40 uppercase tracking-wider">7-day free trial. Cancel anytime.</p>
    </div>
  </div>
</section>
