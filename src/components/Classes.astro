---
import config from '../../site.json';
const classes = config.classes;
---
<section id="classes" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-accent text-accent text-xs tracking-widest uppercase mb-4">Train Hard</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Our Classes</h2>
      <p class="text-base-content/60 mt-4 max-w-md mx-auto">From high-intensity sweat sessions to mindful recovery — find your fit.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
      {classes.map((cls) => (
        <div class="card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <!-- Image -->
          <div class="relative aspect-[4/3] bg-base-300/50 overflow-hidden rounded-t-2xl">
            <img src={cls.image} alt={cls.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute top-3 right-3">
              <span class="badge badge-accent font-semibold">${cls.price}/class</span>
            </div>
          </div>

          <div class="card-body p-5">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-heading font-semibold text-xl">{cls.name}</h3>
              <span class="text-xs text-base-content/50 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {cls.duration}
              </span>
            </div>
            <p class="text-base-content/60 text-sm leading-relaxed">{cls.description}</p>
            <div class="card-actions mt-4">
              <button class="btn btn-outline btn-sm btn-accent w-full">Book Class</button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
