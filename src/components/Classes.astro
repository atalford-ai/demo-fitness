---
import config from '../../site.json';
const classes = config.classes;
---
<section id="classes" class="py-24 px-6 lg:px-12 bg-base-200">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <h2 class="text-5xl md:text-6xl font-heading font-bold uppercase tracking-wide">Our Classes</h2>
      <p class="text-base-content/50 mt-4 uppercase tracking-wider text-sm">Find your fight. Pick your poison.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto stagger-children">
      {classes.map((cls) => (
        <div class="card image-full shadow-xl group cursor-pointer">
          <figure>
            <img src={cls.image} alt={cls.name} class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </figure>
          <div class="card-body justify-end">
            <div class="flex items-center justify-between">
              <h3 class="card-title text-2xl font-heading uppercase tracking-wide">{cls.name}</h3>
              <span class="badge badge-accent font-bold">{cls.duration}</span>
            </div>
            <p class="text-white/0 group-hover:text-white/80 transition-all duration-300 text-sm leading-relaxed">
              {cls.description}
            </p>
            <div class="card-actions justify-between items-center mt-2">
              <span class="text-accent font-heading text-xl">${cls.price}/class</span>
              <button class="btn btn-accent btn-sm uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-300">Book Now</button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
