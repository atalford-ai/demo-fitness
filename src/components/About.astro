---
import config from '../../site.json';
---
<section id="about" class="hero min-h-[60vh]" style="background-image: url('https://images.unsplash.com/photo-1593079831268-3381b0db4a77?w=1600&h=900&fit=crop');">
  <div class="hero-overlay bg-black/70"></div>
  <div class="hero-content flex-col text-neutral-content text-center py-20">
    <div class="max-w-3xl fade-in-up">
      <h2 class="text-5xl md:text-7xl font-heading font-bold uppercase tracking-wide mb-4">More Than a Gym</h2>
      <p class="text-white/60 text-lg max-w-xl mx-auto mb-12">
        Iron Temple was built on a belief: fitness should be for everyone. Discipline meets community. Every rep counts toward something bigger.
      </p>
    </div>

    <div class="stats shadow bg-base-100/10 backdrop-blur-sm border border-white/10">
      <div class="stat">
        <div class="stat-title text-white/50 uppercase tracking-wider text-xs">Active Members</div>
        <div class="stat-value text-accent font-heading">2,500+</div>
      </div>
      <div class="stat">
        <div class="stat-title text-white/50 uppercase tracking-wider text-xs">Classes / Week</div>
        <div class="stat-value text-accent font-heading">40+</div>
      </div>
      <div class="stat">
        <div class="stat-title text-white/50 uppercase tracking-wider text-xs">Years Strong</div>
        <div class="stat-value text-accent font-heading">8</div>
      </div>
      <div class="stat">
        <div class="stat-title text-white/50 uppercase tracking-wider text-xs">Expert Trainers</div>
        <div class="stat-value text-accent font-heading">12</div>
      </div>
    </div>
  </div>
</section>
