---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Classes from '../components/Classes.astro';
import Trainers from '../components/Trainers.astro';
import Membership from '../components/Membership.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import config from '../../site.json';
---
<BaseLayout title="Home">
  {config.sections.hero && <Hero />}
  {config.sections.classes && <Classes />}
  {config.sections.trainers && <Trainers />}
  {config.sections.membership && <Membership />}
  {config.sections.about && <About />}
  {config.sections.contact && <Contact />}
</BaseLayout>
